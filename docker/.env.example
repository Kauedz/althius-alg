# === Althius ALG — Variáveis de Produção ===

# Domínio público (Caddy gera SSL automaticamente)
ALTHIUS_DOMAIN=alg.seudominio.com
ALTHIUS_PUBLIC_URL=https://alg.seudominio.com

# Segredo de autenticação (gere com: openssl rand -hex 32)
BETTER_AUTH_SECRET=

# Senha do PostgreSQL (gere com: openssl rand -hex 16)
POSTGRES_PASSWORD=

# Chaves de API dos modelos (coloque as que tiver)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
